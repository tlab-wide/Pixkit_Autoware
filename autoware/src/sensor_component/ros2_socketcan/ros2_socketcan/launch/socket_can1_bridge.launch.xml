<launch>

  <let name="interface" value="can1" />
  <let name="receiver_interval_sec" value="0.01" />
  <let name="sender_timeout_sec" value="0.01" />
  <!-- can1 -->
  <include file="$(find-pkg-share ros2_socketcan)/launch/socket_can1_receiver.launch.py">
    <arg name="interface" value="$(var interface)" />
    <arg name="interval_sec" value="$(var receiver_interval_sec)" />
  </include>

  <include file="$(find-pkg-share ros2_socketcan)/launch/socket_can1_sender.launch.py">
    <arg name="interface" value="$(var interface)" />
    <arg name="timeout_sec" value="$(var sender_timeout_sec)" />
  </include>

</launch>
